{
  "name": "living-resume",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run embeddings:verify && npm run test:url-evals && next build",
    "cf:build": "npm run embeddings:verify && npm run test:url-evals && opennextjs-cloudflare build",
    "cf:preview": "wrangler dev",
    "cf:deploy": "node --import tsx scripts/cf-deploy.ts",
    "start": "next start",
    "lint": "next lint",
    "test": "npm run embeddings:verify && node --import tsx --test tests/**/*.test.ts",
    "test:url-evals": "node --import tsx --test tests/url-fit-analysis.eval.test.ts",
    "bench:fit": "node --import tsx scripts/benchmark-fit-analysis.ts",
    "content:build": "node --import tsx scripts/build-content-index.ts",
    "embeddings:build": "node --import tsx scripts/build-embeddings.ts",
    "embeddings:verify": "node --import tsx scripts/verify-embeddings.ts"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "next": "^15.2.9",
    "pdfjs-dist": "^5.5.207",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@opennextjs/cloudflare": "^1.17.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.2.9",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "wrangler": "^4.71.0"
  }
}
